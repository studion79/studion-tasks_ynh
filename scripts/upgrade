#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
ynh_script_progression "Stopping $app's service..."
ynh_systemctl --service="$app" --action="stop"

#=================================================
ynh_script_progression "Upgrading source files..."

# Keep .env (secrets) across the upgrade; uploads are in $data_dir
ynh_setup_source --dest_dir="$install_dir" --full_replace --keep=".env"
chown -R "$app:www-data" "$install_dir"

# Re-create uploads symlink (wiped by full_replace)
rm -rf "$install_dir/public/uploads"
ln -s "$data_dir/uploads" "$install_dir/public/uploads"
chown -h "$app:www-data" "$install_dir/public/uploads"

#=================================================
ynh_script_progression "Rebuilding the app..."

pushd "$install_dir"
npm ci --legacy-peer-deps 2>&1
npx prisma generate 2>&1
npm run build 2>&1
npm prune --production --legacy-peer-deps 2>&1
popd

#=================================================
ynh_script_progression "Updating $app's configuration..."

# Ensure auth_secret exists (first upgrade from a pre-secret install)
ynh_app_setting_set_default --key=auth_secret --value="$(ynh_string_random --length=64)"

ynh_config_add --template="app.env" --destination="$install_dir/.env"
chmod 400 "$install_dir/.env"
chown "$app:$app" "$install_dir/.env"

#=================================================
ynh_script_progression "Running database migrations..."

pushd "$install_dir"
LIBSQL_DATABASE_URL="file:$data_dir/db.sqlite" node scripts/apply-migrations.js 2>&1
popd

#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

# Ensure uploads dir permissions (nginx must be able to read for direct serving)
chown -R "$app:www-data" "$data_dir/uploads"
chmod 755 "$data_dir/uploads"
find "$data_dir/uploads" -type f -exec chmod 644 {} \;

# Ensure the app user is in the postdrop group (idempotent)
usermod -a -G postdrop "$app"

ynh_config_add_nginx
ynh_config_add_systemd
yunohost service add "$app" --description="Task App service" --log="/var/log/$app/$app.log"
ynh_config_add_logrotate

#=================================================
ynh_script_progression "Starting $app's service..."
ynh_systemctl --service="$app" --action="start"

#=================================================
ynh_script_progression "Upgrade of $app completed"
